/**
 * TalentHub Firestore Security Rules
 * 
 * Core Philosophy:
 * This ruleset implements a robust, multi-role security model centered around the Talent Creator
 * and Client/Student relationship. It prioritizes "Authorization Independence" by relying on 
 * denormalized ownership fields (e.g., userId, talentCreatorUserId) within documents to avoid 
 * expensive cross-document lookups (get() calls).
 * 
 * Data Structure:
 * - /users/{userId}: Private user profiles accessible only by the owner.
 * - /roles_admin/{userId}: Sentinel collection where the existence of a UID document grants admin privileges.
 * - /skillCategories, /skills: Global metadata collections, publicly readable, admin-managed.
 * - /talentCreatorProfiles: Public-facing profiles for creators. Subcollections (experiences, 
 *   portfolios, services) follow the creator's ownership.
 * - /workshops, /jobRequests, /enrollments, /userReviews: Collaborative or public entities 
 *   secured by denormalized participant UIDs.
 * - /conversations: Secured via a 'participantIds' array for membership-based access.
 * 
 * Key Security Decisions:
 * 1. Default Posture: All writes require authenticated ownership or administrative privilege.
 * 2. Public Readability: Discovery-focused collections (Profiles, Workshops, Skills) are 
 *    publicly readable to facilitate platform search.
 * 3. Relational Integrity: On creation, documents must include a UID field matching the 
 *    authenticated user to establish ownership. These fields are immutable on update.
 * 4. Admin Override: A dedicated '/roles_admin' path provides a high-performance check for 
 *    administrative actions across the platform.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    /**
     * @description Checks if the request is from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is a registered administrator.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Verifies ownership and ensures the document exists for destructive operations.
     */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the private User profile.
     * @path /users/{userId}
     * @allow (get, list, create, update) if UID matches userId.
     * @deny (delete) users cannot delete their own root profile record.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false;

      /**
       * @description Rules for user-specific notifications.
       * @path /users/{userId}/notifications/{notificationId}
       * @allow (read, write) if user is the path owner.
       * @principle Enforces strict ownership for private subcollections.
       */
      match /notifications/{notificationId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Administrative sentinel collection.
     * @path /roles_admin/{userId}
     * @allow (get) for the user themselves or admins.
     * @deny (list, write) standard users cannot browse admins or grant themselves privileges.
     * @principle Database-Based Access Control (DBAC).
     */
    match /roles_admin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list, create, update, delete: if isAdmin();
    }

    /**
     * @description Global skill categories.
     * @path /skillCategories/{skillCategoryId}
     * @allow (read) public.
     * @allow (write) admin only.
     * @principle Public read with admin-only writes for platform metadata.
     */
    match /skillCategories/{skillCategoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Global specific skills.
     * @path /skills/{skillId}
     * @allow (read) public.
     * @allow (write) admin only.
     * @principle Public read with admin-only writes for platform metadata.
     */
    match /skills/{skillId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Publicly readable Talent Creator profiles.
     * @path /talentCreatorProfiles/{talentCreatorId}
     * @allow (read) public.
     * @allow (write) if owner of the profile (UID matches doc ID).
     * @principle Public discovery with owner-managed content.
     */
    match /talentCreatorProfiles/{talentCreatorId} {
      allow get, list: if true;
      allow create: if isOwner(talentCreatorId) && request.resource.data.userId == talentCreatorId;
      allow update: if isExistingOwner(talentCreatorId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isAdmin(); // Only admins can delete profiles

      /**
       * @description Experiences, Portfolios, and Services subcollections.
       * @path /talentCreatorProfiles/{talentCreatorId}/...
       * @allow (read) public.
       * @allow (write) if authenticated owner of the parent profile.
       * @principle Subcollection access inherited from parent ownership.
       */
      match /experiences/{id} {
        allow get, list: if true;
        allow create: if isOwner(talentCreatorId) && request.resource.data.talentCreatorProfileId == talentCreatorId;
        allow update, delete: if isExistingOwner(talentCreatorId);
      }

      match /portfolios/{portfolioId} {
        allow get, list: if true;
        allow create: if isOwner(talentCreatorId) && request.resource.data.talentCreatorProfileId == talentCreatorId;
        allow update, delete: if isExistingOwner(talentCreatorId);

        match /assets/{assetId} {
          allow get, list: if true;
          allow create: if isOwner(talentCreatorId) && request.resource.data.portfolioId == portfolioId;
          allow update, delete: if isExistingOwner(talentCreatorId);
        }
      }

      match /services/{id} {
        allow get, list: if true;
        allow create: if isOwner(talentCreatorId) && request.resource.data.talentCreatorProfileId == talentCreatorId;
        allow update, delete: if isExistingOwner(talentCreatorId);
      }
    }

    /**
     * @description Platform workshops created by Talent Creators.
     * @path /workshops/{workshopId}
     * @allow (read) public.
     * @allow (write) if authenticated user is the talentCreatorUserId.
     * @principle Validates relational integrity using denormalized creator ID.
     */
    match /workshops/{workshopId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.talentCreatorUserId == request.auth.uid;
      allow update, delete: if resource != null && resource.data.talentCreatorUserId == request.auth.uid;
    }

    /**
     * @description Hiring requests between Clients and Talent Creators.
     * @path /jobRequests/{jobRequestId}
     * @allow (read, write) if user is either the 'clientId' or the 'talentCreatorUserId'.
     * @principle Shared access for closed collaborators via denormalized UIDs.
     */
    match /jobRequests/{jobRequestId} {
      allow get, list: if isSignedIn() && (request.auth.uid == resource.data.clientId || request.auth.uid == resource.data.talentCreatorUserId);
      allow create: if isSignedIn() && request.resource.data.clientId == request.auth.uid;
      allow update: if resource != null && (request.auth.uid == resource.data.clientId || request.auth.uid == resource.data.talentCreatorUserId);
      allow delete: if isAdmin();
    }

    /**
     * @description Workshop enrollment records.
     * @path /enrollments/{enrollmentId}
     * @allow (read, write) if user is 'studentId' or 'talentCreatorUserId'.
     * @principle Restricted access based on participation role.
     */
    match /enrollments/{enrollmentId} {
      allow get, list: if isSignedIn() && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.talentCreatorUserId);
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update: if resource != null && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.talentCreatorUserId);
      allow delete: if isAdmin();
    }

    /**
     * @description Reviews for Talent Creators.
     * @path /userReviews/{userReviewId}
     * @allow (read) public.
     * @allow (create) by the reviewer.
     * @allow (update) by the reviewed creator (for approval/flags) or admin.
     * @principle Public consumption with specific management rights for participants.
     */
    match /userReviews/{userReviewId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.reviewerId == request.auth.uid;
      allow update: if resource != null && (request.auth.uid == resource.data.reviewedTalentCreatorUserId || isAdmin());
      allow delete: if isAdmin();
    }

    /**
     * @description Reviews for Workshops.
     * @path /workshopReviews/{workshopReviewId}
     * @allow (read) public.
     * @allow (create) by the reviewer (student).
     * @principle Multi-party review system.
     */
    match /workshopReviews/{workshopReviewId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.reviewerId == request.auth.uid;
      allow update: if resource != null && (request.auth.uid == resource.data.reviewedWorkshopCreatorUserId || isAdmin());
      allow delete: if isAdmin();
    }

    /**
     * @description Private message conversations.
     * @path /conversations/{conversationId}
     * @allow (read, write) if the user's UID is in the 'participantIds' array.
     * @principle Array-based membership check for shared access.
     */
    match /conversations/{conversationId} {
      allow get, list: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;
      allow update: if resource != null && request.auth.uid in resource.data.participantIds;
      allow delete: if isAdmin();

      /**
       * @description Individual messages within a conversation.
       * @path /conversations/{conversationId}/messages/{messageId}
       * @allow (read, write) if UID is in the denormalized 'conversationParticipantIds'.
       * @principle Authorization Independence via denormalized membership lists.
       */
      match /messages/{messageId} {
        allow get, list: if isSignedIn() && request.auth.uid in resource.data.conversationParticipantIds;
        allow create: if isSignedIn() && request.auth.uid in request.resource.data.conversationParticipantIds && request.resource.data.senderId == request.auth.uid;
        allow update: if resource != null && request.auth.uid in resource.data.conversationParticipantIds;
        allow delete: if false; // Messages are immutable for audit/safety
      }
    }
  }
}