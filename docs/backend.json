
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account on the TalentHub platform.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "profilePhotoUrl": { "type": "string", "format": "uri" },
        "bio": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "roles", "createdAt", "updatedAt"]
    },
    "Show": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Show",
      "type": "object",
      "description": "Represents an upcoming show or performance for a talent creator.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "venue": { "type": "string" },
        "payout": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "venue", "date", "createdAt", "updatedAt"]
    },
    "Workshop": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Workshop",
      "type": "object",
      "description": "Represents a workshop hosted by a talent creator.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "participants": { "type": "number" },
        "maxParticipants": { "type": "number" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "category", "price", "date", "createdAt", "updatedAt"]
    },
    "SkillCategory": {
      "title": "SkillCategory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Core user profile."
        }
      },
      {
        "path": "/users/{userId}/shows/{showId}",
        "definition": {
          "entityName": "Show",
          "schema": { "$ref": "#/backend/entities/Show" },
          "description": "Shows managed by a specific user."
        }
      },
      {
        "path": "/users/{userId}/workshops/{workshopId}",
        "definition": {
          "entityName": "Workshop",
          "schema": { "$ref": "#/backend/entities/Workshop" },
          "description": "Workshops managed by a specific user."
        }
      }
    ]
  }
}
